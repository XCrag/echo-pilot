{
  "schedule": {
    "baseDelaySeconds": 120,
    "jitterSeconds": 20
  },
  "commands": [
    {
      "name": "codex",
      "command": "codex",
      "args": [
        "exec",
        "--model",
        "gpt-5.5",
        "--config",
        "model_reasoning_effort=\"low\"",
        "--skip-git-repo-check",
        "--sandbox",
        "read-only",
        "--ignore-rules",
        "--ephemeral",
        "{{arithmeticPrompt}}"
      ]
    },
    {
      "name": "claude",
      "command": "sh",
      "args": [
        "-c",
        "claude -p --bare --tools \"\" --disable-slash-commands --strict-mcp-config --system-prompt \"\" --output-format json \"{{arithmeticPrompt}}\" | jq '{result, usage}'"
      ]
    }
  ]
}
