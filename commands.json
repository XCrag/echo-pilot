{
  "schedule": {
    "baseDelaySeconds": 120,
    "jitterSeconds": 20
  },
  "commands": [
    {
      "name": "codex",
      "command": "./bin/codex-json.js",
      "args": [
        "exec",
        "--model",
        "gpt-5.6-sol",
        "--config",
        "model_reasoning_effort=\"none\"",
        "--config",
        "web_search=\"disabled\"",
        "--disable",
        "shell_tool",
        "--disable",
        "multi_agent",
        "--disable",
        "hooks",
        "--disable",
        "plugins",
        "--skip-git-repo-check",
        "--sandbox",
        "read-only",
        "--ignore-rules",
        "--ephemeral",
        "{{arithmeticPrompt}}"
      ]
    },
    {
      "name": "claude",
      "command": "sh",
      "args": [
        "-c",
        "claude -p --bare --disable-slash-commands --strict-mcp-config --system-prompt \"\" --output-format json \"{{arithmeticPrompt}}\" | jq '{result, usage}'"
      ]
    }
  ]
}
